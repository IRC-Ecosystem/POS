<%- include("../partials/header", { pageTitle, bodyClass: "bg-slate-100 text-slate-900" }) %>
  <% const currentMode = typeof viewMode !== 'undefined' ? viewMode : 'transaction'; %>
  <% const payableTransactions = transactions.filter((transaction) => ['approved', 'pending_payment'].includes(transaction.status)); %>
  <% const incomingTransactions = transactions.filter((transaction) => transaction.status === 'pending'); %>
  <% const historyTransactions = transactions.filter((transaction) => transaction.status !== 'pending'); %>
  <% const displayTransactions = currentMode === 'incoming' ? transactions : [...incomingTransactions, ...historyTransactions]; %>
  <% const basePath = currentMode === 'incoming' ? '/kasir/incoming' : '/kasir'; %>

  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "POS Kasir",
      sidebarDescription: "Meja kerja kasir untuk transaksi toko offline dan order masuk.",
      sidebarLinks: [
        { href: "/kasir", label: "Transaksi", short: "TR" },
        { href: "/kasir/incoming", label: "Transaksi Masuk", short: "IN", matchPrefix: "/kasir/incoming" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="flex-1">
      <header class="sticky top-0 z-20 border-b border-slate-200 bg-white/95 px-4 py-4 backdrop-blur lg:px-6">
        <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">WarungPOS</p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight text-slate-950"><%= currentMode === 'incoming' ? 'Transaksi Masuk' : 'Transaksi Kasir' %></h2>
          </div>
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
            <% stats.forEach((stat) => { %>
              <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                <p class="text-[11px] font-medium text-slate-500"><%= stat.label %></p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= stat.value %></p>
              </div>
            <% }) %>
          </div>
        </div>
      </header>

      <section class="p-4 lg:p-6">
        <% if (typeof dashboardError !== 'undefined' && dashboardError) { %>
          <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= dashboardError %>
          </div>
        <% } %>

        <% if (currentMode === 'transaction') { %>
          <form id="direct-sale-form" action="/kasir/direct-sale" method="POST">
            <section class="overflow-hidden rounded-xl border border-slate-200 bg-white">
              <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  <h3 class="text-lg font-semibold text-slate-950">Pilih Produk</h3>
                  <p class="mt-1 text-sm text-slate-500">Klik tambah untuk memasukkan item ke invoice aktif.</p>
                </div>
                <div class="flex items-center gap-2">
                  <span class="rounded-lg bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700"><%= productPagination.totalItems %> produk</span>
                  <button type="button" id="clear-order" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">
                    Bersihkan Invoice
                  </button>
                </div>
              </div>

              <% if (products.length === 0) { %>
                <div class="px-6 py-14 text-center">
                  <h3 class="text-lg font-semibold text-slate-950">Produk belum tersedia</h3>
                  <p class="mt-2 text-sm text-slate-500">Tambahkan produk dari dashboard operator.</p>
                </div>
              <% } else { %>
                <div class="grid gap-4 p-4 md:grid-cols-2 xl:grid-cols-3">
                  <% products.forEach((product) => { %>
                    <article
                      class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md"
                      data-product-card
                      data-product-id="<%= product.id %>"
                    >
                      <input type="hidden" name="product_ids" value="<%= product.id %>">
                      <div class="p-4">
                        <div class="flex items-start gap-3">
                          <% if (product.gambar) { %>
                            <img src="<%= product.gambar %>" alt="<%= product.nama_produk %>" class="h-20 w-20 shrink-0 rounded-2xl object-cover ring-1 ring-slate-200">
                          <% } else { %>
                            <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-slate-100 text-base font-bold text-slate-500 ring-1 ring-slate-200">
                              <%= (product.nama_produk || 'P').slice(0, 2).toUpperCase() %>
                            </div>
                          <% } %>
                          <div class="min-w-0 flex-1">
                            <div class="flex items-start justify-between gap-3">
                              <div class="min-w-0">
                                <p class="text-lg font-semibold leading-snug text-slate-950"><%= product.nama_produk %></p>
                                <p class="mt-1 text-sm text-slate-500"><%= product.kategori || 'Umum' %></p>
                              </div>
                              <span class="shrink-0 rounded-full px-3 py-1 text-xs font-semibold <%= Number(product.stock) > 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-rose-50 text-rose-700' %>">
                                Stok <%= product.stock %>
                              </span>
                            </div>
                          </div>
                        </div>

                        <div class="mt-5 flex items-end justify-between gap-3">
                          <div>
                            <p class="text-xs font-medium uppercase tracking-[0.16em] text-slate-400">Harga</p>
                            <p class="mt-1 text-2xl font-semibold tracking-tight text-slate-950"><%= product.harga_formatted %></p>
                          </div>
                          <div class="flex h-12 items-center rounded-xl border border-slate-200 bg-slate-50">
                            <button type="button" class="h-12 w-12 text-lg font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-950" data-decrease-product="<%= product.id %>" aria-label="Kurangi <%= product.nama_produk %>">-</button>
                            <input
                              type="number"
                              min="0"
                              max="<%= product.stock %>"
                              step="1"
                              name="qty_<%= product.id %>"
                              value="0"
                              data-pos-qty
                              data-product-id="<%= product.id %>"
                              data-name="<%= product.nama_produk %>"
                              data-price="<%= product.harga_number %>"
                              data-stock="<%= product.stock %>"
                              class="h-12 w-14 border-x border-slate-200 bg-white text-center text-sm font-semibold outline-none"
                            >
                            <button type="button" class="h-12 w-12 text-xl font-semibold text-blue-600 transition hover:bg-blue-50 hover:text-blue-800 disabled:text-slate-300" data-add-product="<%= product.id %>" <%= Number(product.stock) <= 0 ? 'disabled' : '' %> aria-label="Tambah <%= product.nama_produk %>">+</button>
                          </div>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>

                <nav class="flex flex-col gap-3 border-t border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                  <p class="text-sm text-slate-500">
                    Produk <span class="font-semibold text-slate-900"><%= productPagination.currentPage %></span>/<span class="font-semibold text-slate-900"><%= productPagination.totalPages %></span>
                  </p>
                  <div class="flex gap-2">
                    <a
                      href="/kasir?<%= new URLSearchParams({ productPage: productPagination.prevPage, transactionPage: transactionPagination.currentPage }).toString() %>"
                      class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= productPagination.hasPrev ? 'bg-white text-slate-700 hover:bg-slate-50' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                    >
                      Sebelumnya
                    </a>
                    <a
                      href="/kasir?<%= new URLSearchParams({ productPage: productPagination.nextPage, transactionPage: transactionPagination.currentPage }).toString() %>"
                      class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= productPagination.hasNext ? 'border-slate-950 bg-slate-950 text-white hover:bg-blue-700' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                    >
                      Berikutnya
                    </a>
                  </div>
                </nav>
              <% } %>
            </section>

            <section class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white">
              <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  <h3 class="text-lg font-semibold text-slate-950">Invoice Aktif</h3>
                  <p class="mt-1 text-sm text-slate-500">Belanja walk-in customer sebelum dibuat invoice.</p>
                </div>
                <span id="cart-count" class="rounded-lg bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-700">0 item</span>
              </div>

              <div id="empty-order" class="px-4 py-10 text-center">
                <p class="text-sm font-medium text-slate-700">Belum ada produk dipilih</p>
                <p class="mt-1 text-xs text-slate-500">Pilih produk dari daftar di atas.</p>
              </div>

              <div id="order-items" class="hidden overflow-x-auto"></div>

              <div class="grid gap-4 border-t border-slate-200 bg-slate-50 px-4 py-4 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-end">
                <div class="rounded-xl bg-white p-4 ring-1 ring-slate-200">
                  <div class="grid gap-2 text-sm">
                    <div class="flex justify-between gap-3 text-slate-600">
                      <span>Subtotal</span>
                      <span id="direct-sale-subtotal" class="font-semibold text-slate-900">Rp0</span>
                    </div>
                    <div class="flex justify-between gap-3 text-slate-600">
                      <span>Fee POS 1%</span>
                      <span id="direct-sale-fee" class="font-semibold text-slate-900">Rp0</span>
                    </div>
                  </div>
                  <div class="mt-4 flex items-end justify-between gap-4 border-t border-slate-200 pt-4">
                    <p class="text-sm font-medium text-slate-500">Total Tagihan</p>
                    <p id="direct-sale-total" class="text-3xl font-semibold tracking-tight text-slate-950">Rp0</p>
                  </div>
                </div>
                <button
                  type="submit"
                  id="create-invoice-button"
                  data-skip-loading="true"
                  class="rounded-xl bg-blue-600 px-5 py-4 text-sm font-semibold text-white transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-slate-300"
                  disabled
                >
                  Buat Invoice
                </button>
              </div>
            </section>
          </form>

          <section class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white">
            <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-4 lg:flex-row lg:items-center lg:justify-between">
              <div>
                <h3 class="text-lg font-semibold text-slate-950">Antrian Bayar</h3>
                <p class="mt-1 text-sm text-slate-500">Invoice yang sudah dibuat dan menunggu pembayaran.</p>
              </div>
              <span class="rounded-lg bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700"><%= payableTransactions.length %> invoice</span>
            </div>

            <% if (payableTransactions.length === 0) { %>
              <div class="px-4 py-10 text-center text-sm text-slate-500">Belum ada invoice siap bayar.</div>
            <% } else { %>
              <div class="grid gap-4 bg-slate-50/50 p-4 md:grid-cols-2 xl:grid-cols-3">
                <% payableTransactions.forEach((transaction) => { %>
                  <article class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="absolute left-0 right-0 top-0 border-t-4 border-dashed border-slate-200"></div>
                    <div class="px-5 pb-4 pt-5">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Invoice</p>
                          <p class="mt-1 truncate text-sm font-semibold text-slate-950"><%= transaction.invoice %></p>
                          <p class="mt-1 text-xs text-slate-500"><%= transaction.user_id ? transaction.customer_name : 'Walk-in Customer' %></p>
                        </div>
                        <span class="rounded-full px-3 py-1 text-[11px] font-semibold <%= transaction.status === 'pending_payment' ? 'bg-violet-50 text-violet-700' : 'bg-sky-50 text-sky-700' %>"><%= transaction.status %></span>
                      </div>

                      <div class="my-4 border-t border-dashed border-slate-200"></div>

                      <div class="space-y-2">
                        <% transaction.items.slice(0, 3).forEach((item) => { %>
                          <div class="flex items-start justify-between gap-3 text-sm">
                            <div class="min-w-0">
                              <p class="truncate font-medium text-slate-800"><%= item.nama_produk || 'Produk' %></p>
                              <p class="text-xs text-slate-500"><%= item.qty %> x <%= item.price_formatted %></p>
                            </div>
                            <p class="shrink-0 font-semibold text-slate-950"><%= item.subtotal_formatted %></p>
                          </div>
                        <% }) %>
                        <% if (transaction.items.length > 3) { %>
                          <p class="text-xs font-medium text-slate-500">+ <%= transaction.items.length - 3 %> item lain</p>
                        <% } %>
                      </div>

                      <div class="my-4 border-t border-dashed border-slate-200"></div>

                      <div class="space-y-2 text-sm text-slate-600">
                        <div class="flex justify-between gap-3">
                          <span>Subtotal</span>
                          <span class="font-semibold text-slate-900"><%= transaction.subtotal_formatted %></span>
                        </div>
                        <div class="flex justify-between gap-3">
                          <span>Fee POS</span>
                          <span class="font-semibold text-slate-900"><%= transaction.fee_formatted %></span>
                        </div>
                      </div>

                      <div class="mt-4 rounded-xl bg-slate-950 px-4 py-3 text-white">
                        <div class="flex items-end justify-between gap-3">
                          <span class="text-sm text-slate-300">Total</span>
                          <span class="text-2xl font-semibold"><%= transaction.grand_total_formatted %></span>
                        </div>
                      </div>

                      <button type="button" data-open-modal="pay-modal-<%= transaction.id %>" class="mt-4 w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700">
                        Bayar Invoice
                      </button>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
          </section>
        <% } else { %>
          <section class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-4 lg:flex-row lg:items-center lg:justify-between">
              <div>
                <h3 class="text-lg font-semibold text-slate-950">Transaksi Masuk</h3>
                <p class="mt-1 text-sm text-slate-500">Order konsumen, approval, pembayaran, dan riwayat transaksi.</p>
              </div>
              <span class="rounded-lg bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700"><%= transactionPagination.totalItems %> transaksi</span>
            </div>

            <% if (displayTransactions.length === 0) { %>
              <div class="px-4 py-12 text-center text-sm text-slate-500">Belum ada transaksi masuk.</div>
            <% } else { %>
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                  <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.12em] text-slate-400">
                    <tr>
                      <th class="px-4 py-3 font-semibold">Invoice</th>
                      <th class="px-4 py-3 font-semibold">Pelanggan</th>
                      <th class="px-4 py-3 font-semibold">Total</th>
                      <th class="px-4 py-3 font-semibold">Status</th>
                      <th class="px-4 py-3 font-semibold">Aksi</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100 bg-white">
                    <% displayTransactions.forEach((transaction) => { %>
                      <tr>
                        <td class="px-4 py-3">
                          <p class="font-semibold text-slate-950"><%= transaction.invoice %></p>
                          <p class="mt-1 text-xs text-slate-500"><%= transaction.created_at_formatted %></p>
                        </td>
                        <td class="px-4 py-3">
                          <p class="font-medium text-slate-900"><%= transaction.user_id ? transaction.customer_name : 'Walk-in Customer' %></p>
                          <p class="mt-1 text-xs text-slate-500"><%= transaction.customer_email || '-' %></p>
                        </td>
                        <td class="px-4 py-3 font-semibold text-slate-950"><%= transaction.grand_total_formatted %></td>
                        <td class="px-4 py-3">
                          <span class="rounded-lg px-2.5 py-1 text-xs font-semibold
                            <%= transaction.status === 'pending' ? 'bg-amber-50 text-amber-700' : '' %>
                            <%= transaction.status === 'pending_payment' ? 'bg-violet-50 text-violet-700' : '' %>
                            <%= transaction.status === 'approved' ? 'bg-sky-50 text-sky-700' : '' %>
                            <%= transaction.status === 'paid' ? 'bg-emerald-50 text-emerald-700' : '' %>
                            <%= transaction.status === 'rejected' ? 'bg-rose-50 text-rose-700' : '' %>
                          "><%= transaction.status %></span>
                          <% if (transaction.payment_method) { %>
                            <p class="mt-1 text-[11px] uppercase tracking-[0.16em] text-slate-400"><%= transaction.payment_method %></p>
                          <% } %>
                        </td>
                        <td class="px-4 py-3">
                          <div class="flex flex-wrap gap-2">
                            <button type="button" data-open-modal="detail-modal-<%= transaction.id %>" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">
                              Detail
                            </button>
                            <% if (transaction.status === 'pending') { %>
                              <form action="/kasir/approve/<%= transaction.id %>" method="POST">
                                <button type="submit" class="rounded-lg bg-sky-50 px-3 py-2 text-xs font-semibold text-sky-700 transition hover:bg-sky-100">
                                  Approve
                                </button>
                              </form>
                              <form action="/kasir/reject/<%= transaction.id %>" method="POST">
                                <button type="submit" class="rounded-lg bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100">
                                  Tolak
                                </button>
                              </form>
                            <% } %>
                            <% if (['approved', 'pending_payment'].includes(transaction.status)) { %>
                              <button type="button" data-open-modal="pay-modal-<%= transaction.id %>" class="rounded-lg bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700 transition hover:bg-emerald-100">
                                Bayar
                              </button>
                            <% } %>
                            <% if (transaction.status === 'paid') { %>
                              <a href="/kasir/receipt/<%= transaction.id %>" class="rounded-lg bg-slate-950 px-3 py-2 text-xs font-semibold text-white transition hover:bg-blue-700">
                                Struk
                              </a>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>

            <nav class="flex flex-col gap-3 border-t border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-slate-500">
                Transaksi <span class="font-semibold text-slate-900"><%= transactionPagination.currentPage %></span>/<span class="font-semibold text-slate-900"><%= transactionPagination.totalPages %></span>
              </p>
              <div class="flex gap-2">
                <a
                  href="<%= basePath %>?<%= new URLSearchParams({ productPage: productPagination.currentPage, transactionPage: transactionPagination.prevPage }).toString() %>"
                  class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= transactionPagination.hasPrev ? 'bg-white text-slate-700 hover:bg-slate-50' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                >
                  Sebelumnya
                </a>
                <a
                  href="<%= basePath %>?<%= new URLSearchParams({ productPage: productPagination.currentPage, transactionPage: transactionPagination.nextPage }).toString() %>"
                  class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= transactionPagination.hasNext ? 'border-slate-950 bg-slate-950 text-white hover:bg-blue-700' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                >
                  Berikutnya
                </a>
              </div>
            </nav>
          </section>
        <% } %>
      </section>
    </main>
  </div>

  <% transactions.forEach((transaction) => { %>
    <div id="detail-modal-<%= transaction.id %>" data-modal-overlay class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4">
      <div class="w-full max-w-3xl rounded-xl bg-white shadow-[0_24px_70px_rgba(15,23,42,0.24)]">
        <div class="flex items-start justify-between gap-4 border-b border-slate-200 px-5 py-4">
          <div>
            <h3 class="text-xl font-semibold text-slate-950">Detail Transaksi</h3>
            <p class="mt-1 text-sm text-slate-500"><%= transaction.invoice %> - <%= transaction.user_id ? transaction.customer_name : 'Walk-in Customer' %></p>
          </div>
          <button type="button" data-close-modal="detail-modal-<%= transaction.id %>" class="rounded-lg bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-500 hover:bg-slate-200">x</button>
        </div>

        <div class="px-5 py-5">
          <div class="overflow-hidden rounded-xl border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50 text-left text-slate-500">
                <tr>
                  <th class="px-4 py-3 font-medium">Item</th>
                  <th class="px-4 py-3 font-medium">Qty</th>
                  <th class="px-4 py-3 font-medium">Harga</th>
                  <th class="px-4 py-3 font-medium">Subtotal</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                <% transaction.items.forEach((item) => { %>
                  <tr>
                    <td class="px-4 py-3">
                      <p class="font-semibold text-slate-950"><%= item.nama_produk || 'Produk' %></p>
                      <p class="mt-1 text-xs text-slate-500"><%= item.kategori || 'Umum' %></p>
                    </td>
                    <td class="px-4 py-3 text-slate-700"><%= item.qty %></td>
                    <td class="px-4 py-3 text-slate-700"><%= item.price_formatted %></td>
                    <td class="px-4 py-3 font-semibold text-slate-950"><%= item.subtotal_formatted %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-medium text-slate-500">Subtotal</p>
              <p class="mt-1 font-semibold text-slate-950"><%= transaction.subtotal_formatted %></p>
            </div>
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-medium text-slate-500">Fee</p>
              <p class="mt-1 font-semibold text-slate-950"><%= transaction.fee_formatted %></p>
            </div>
            <div class="rounded-xl bg-slate-950 p-4 text-white">
              <p class="text-xs font-medium text-slate-300">Grand Total</p>
              <p class="mt-1 font-semibold"><%= transaction.grand_total_formatted %></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (['approved', 'pending_payment'].includes(transaction.status)) { %>
      <div id="pay-modal-<%= transaction.id %>" data-modal-overlay class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4">
        <div class="w-full max-w-xl overflow-hidden rounded-2xl bg-slate-100 shadow-[0_24px_70px_rgba(15,23,42,0.24)]">
          <form action="/kasir/pay/<%= transaction.id %>" method="POST" class="p-4">
            <div class="relative rounded-2xl bg-white px-5 py-5 shadow-sm">
              <button type="button" data-close-modal="pay-modal-<%= transaction.id %>" class="absolute right-4 top-4 rounded-xl bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-500 hover:bg-slate-200">x</button>

              <div class="border-b border-dashed border-slate-300 pb-4 text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">WarungPOS</p>
                <h3 class="mt-2 text-2xl font-semibold text-slate-950">Struk Pembayaran</h3>
                <p class="mt-1 text-sm text-slate-500"><%= transaction.invoice %></p>
                <p class="mt-1 text-xs text-slate-400"><%= transaction.user_id ? transaction.customer_name : 'Walk-in Customer' %></p>
              </div>

              <div class="space-y-3 border-b border-dashed border-slate-300 py-4">
                <% transaction.items.forEach((item) => { %>
                  <div class="flex items-start justify-between gap-4 text-sm">
                    <div class="min-w-0">
                      <p class="font-semibold leading-snug text-slate-950"><%= item.nama_produk || 'Produk' %></p>
                      <p class="mt-1 text-xs text-slate-500"><%= item.qty %> x <%= item.price_formatted %></p>
                    </div>
                    <p class="shrink-0 font-semibold text-slate-950"><%= item.subtotal_formatted %></p>
                  </div>
                <% }) %>
              </div>

              <div class="space-y-2 border-b border-dashed border-slate-300 py-4 text-sm text-slate-600">
                <div class="flex justify-between gap-3">
                  <span>Subtotal</span>
                  <span class="font-semibold text-slate-950"><%= transaction.subtotal_formatted %></span>
                </div>
                <div class="flex justify-between gap-3">
                  <span>Fee POS 1%</span>
                  <span class="font-semibold text-slate-950"><%= transaction.fee_formatted %></span>
                </div>
                <div class="flex items-end justify-between gap-3 pt-2">
                  <span class="text-base font-semibold text-slate-950">Total</span>
                  <span class="text-3xl font-semibold tracking-tight text-slate-950"><%= transaction.grand_total_formatted %></span>
                </div>
              </div>

              <div class="pt-4">
                <label class="mb-2 block text-sm font-medium text-slate-700">Metode Pembayaran</label>
                <select name="payment_method" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-slate-400 focus:bg-white" required>
                  <option value="">Pilih metode pembayaran</option>
                  <option value="cash" <%= transaction.payment_method === 'cash' ? 'selected' : '' %>>Cash</option>
                  <option value="qris" <%= transaction.payment_method === 'qris' ? 'selected' : '' %>>QRIS</option>
                  <option value="transfer" <%= transaction.payment_method === 'transfer' ? 'selected' : '' %>>Transfer</option>
                  <option value="smartbank" <%= transaction.payment_method === 'smartbank' ? 'selected' : '' %>>SmartBank</option>
                </select>
              </div>

              <div class="mt-5 grid grid-cols-2 gap-2">
                <button type="button" data-close-modal="pay-modal-<%= transaction.id %>" class="rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Batal</button>
                <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700">Proses Bayar</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  <% }) %>

  <div id="invoice-confirm-modal" data-modal-overlay class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4">
    <div class="w-full max-w-lg overflow-hidden rounded-2xl bg-white shadow-[0_24px_70px_rgba(15,23,42,0.24)]">
      <div class="border-b border-slate-200 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-600">Konfirmasi Invoice</p>
        <h3 class="mt-1 text-xl font-semibold text-slate-950">Buat invoice untuk belanja ini?</h3>
        <p class="mt-1 text-sm text-slate-500">Periksa kembali item dan total sebelum invoice masuk ke antrian bayar.</p>
      </div>

      <div class="px-5 py-5">
        <div id="invoice-confirm-items" class="max-h-64 overflow-y-auto rounded-xl border border-slate-200"></div>
        <div class="mt-4 rounded-xl bg-slate-950 p-4 text-white">
          <div class="space-y-2 text-sm text-slate-300">
            <div class="flex justify-between gap-3">
              <span>Subtotal</span>
              <span id="invoice-confirm-subtotal">Rp0</span>
            </div>
            <div class="flex justify-between gap-3">
              <span>Fee POS</span>
              <span id="invoice-confirm-fee">Rp0</span>
            </div>
          </div>
          <div class="mt-3 flex items-end justify-between gap-3 border-t border-white/10 pt-3">
            <span class="text-sm text-slate-300">Total</span>
            <span id="invoice-confirm-total" class="text-2xl font-semibold">Rp0</span>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-2 border-t border-slate-200 bg-slate-50 px-5 py-4">
        <button type="button" data-close-modal="invoice-confirm-modal" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
          Cek Lagi
        </button>
        <button type="button" id="confirm-create-invoice" class="rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
          Buat Invoice
        </button>
      </div>
    </div>
  </div>

  <script>
    const formatRupiah = (value) => new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      maximumFractionDigits: 0
    }).format(value);

    const DIRECT_SALE_FEE_RATE = 0.01;
    const qtyInputs = [...document.querySelectorAll("[data-pos-qty]")];
    const orderItemsTarget = document.getElementById("order-items");
    const emptyOrderTarget = document.getElementById("empty-order");
    const cartCountTarget = document.getElementById("cart-count");
    const invoiceButton = document.getElementById("create-invoice-button");
    const directSaleForm = document.getElementById("direct-sale-form");
    const invoiceConfirmItems = document.getElementById("invoice-confirm-items");
    const invoiceConfirmSubtotal = document.getElementById("invoice-confirm-subtotal");
    const invoiceConfirmFee = document.getElementById("invoice-confirm-fee");
    const invoiceConfirmTotal = document.getElementById("invoice-confirm-total");
    const confirmCreateInvoiceButton = document.getElementById("confirm-create-invoice");
    let invoiceSubmitConfirmed = false;
    const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      "\"": "&quot;",
      "'": "&#039;"
    })[char]);

    const getQtyInput = (productId) => qtyInputs.find((input) => input.dataset.productId === String(productId));

    const clampQty = (input, value) => {
      const stock = Number(input.dataset.stock || 0);
      const nextValue = Math.min(Math.max(Number(value || 0), 0), stock);
      input.value = Number.isInteger(nextValue) ? nextValue : 0;
    };

    const getSelectedItems = () => qtyInputs
      .map((input) => {
        const qty = Number(input.value || 0);
        const price = Number(input.dataset.price || 0);
        return {
          id: input.dataset.productId,
          name: input.dataset.name,
          qty,
          price,
          subtotal: qty * price
        };
      })
      .filter((item) => item.qty > 0);

    const renderOrderItems = (items) => {
      if (!orderItemsTarget || !emptyOrderTarget) return;

      if (items.length === 0) {
        orderItemsTarget.classList.add("hidden");
        emptyOrderTarget.classList.remove("hidden");
        orderItemsTarget.innerHTML = "";
        return;
      }

      emptyOrderTarget.classList.add("hidden");
      orderItemsTarget.classList.remove("hidden");
      orderItemsTarget.innerHTML = `
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.12em] text-slate-400">
            <tr>
              <th class="px-4 py-3 font-semibold">Produk</th>
              <th class="px-4 py-3 font-semibold">Qty</th>
              <th class="px-4 py-3 font-semibold">Harga</th>
              <th class="px-4 py-3 font-semibold">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            ${items.map((item) => `
              <tr>
                <td class="px-4 py-3 font-semibold text-slate-950">${escapeHtml(item.name)}</td>
                <td class="px-4 py-3 text-slate-700">${item.qty}</td>
                <td class="px-4 py-3 text-slate-700">${formatRupiah(item.price)}</td>
                <td class="px-4 py-3 font-semibold text-slate-950">${formatRupiah(item.subtotal)}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      `;
    };

    const getOrderTotals = () => {
      const items = getSelectedItems();
      const subtotal = items.reduce((sum, item) => sum + item.subtotal, 0);
      const fee = Math.round(subtotal * DIRECT_SALE_FEE_RATE);
      return {
        items,
        subtotal,
        fee,
        total: subtotal + fee
      };
    };

    const renderInvoiceConfirm = () => {
      if (!invoiceConfirmItems) return;

      const { items, subtotal, fee, total } = getOrderTotals();
      invoiceConfirmItems.innerHTML = `
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.12em] text-slate-400">
            <tr>
              <th class="px-4 py-3 font-semibold">Produk</th>
              <th class="px-4 py-3 font-semibold">Qty</th>
              <th class="px-4 py-3 font-semibold">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            ${items.map((item) => `
              <tr>
                <td class="px-4 py-3">
                  <p class="font-semibold text-slate-950">${escapeHtml(item.name)}</p>
                  <p class="mt-1 text-xs text-slate-500">${formatRupiah(item.price)} / item</p>
                </td>
                <td class="px-4 py-3 text-slate-700">${item.qty}</td>
                <td class="px-4 py-3 font-semibold text-slate-950">${formatRupiah(item.subtotal)}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      `;

      if (invoiceConfirmSubtotal) invoiceConfirmSubtotal.textContent = formatRupiah(subtotal);
      if (invoiceConfirmFee) invoiceConfirmFee.textContent = formatRupiah(fee);
      if (invoiceConfirmTotal) invoiceConfirmTotal.textContent = formatRupiah(total);
    };

    const updateDirectSaleTotal = () => {
      qtyInputs.forEach((input) => clampQty(input, input.value));

      const items = getSelectedItems();
      const subtotal = items.reduce((sum, item) => sum + item.subtotal, 0);
      const fee = Math.round(subtotal * DIRECT_SALE_FEE_RATE);
      const total = subtotal + fee;
      const subtotalTarget = document.getElementById("direct-sale-subtotal");
      const feeTarget = document.getElementById("direct-sale-fee");
      const totalTarget = document.getElementById("direct-sale-total");

      document.querySelectorAll("[data-product-card]").forEach((card) => {
        const input = getQtyInput(card.dataset.productId);
        card.classList.toggle("border-blue-500", Number(input?.value || 0) > 0);
        card.classList.toggle("bg-blue-50", Number(input?.value || 0) > 0);
      });

      renderOrderItems(items);
      if (subtotalTarget) subtotalTarget.textContent = formatRupiah(subtotal);
      if (feeTarget) feeTarget.textContent = formatRupiah(fee);
      if (totalTarget) totalTarget.textContent = formatRupiah(total);
      if (cartCountTarget) cartCountTarget.textContent = `${items.reduce((sum, item) => sum + item.qty, 0)} item`;
      if (invoiceButton) invoiceButton.disabled = items.length === 0;
    };

    document.querySelectorAll("[data-add-product]").forEach((button) => {
      button.addEventListener("click", () => {
        const input = getQtyInput(button.dataset.addProduct);
        if (!input) return;
        clampQty(input, Number(input.value || 0) + 1);
        updateDirectSaleTotal();
      });
    });

    document.querySelectorAll("[data-decrease-product]").forEach((button) => {
      button.addEventListener("click", () => {
        const input = getQtyInput(button.dataset.decreaseProduct);
        if (!input) return;
        clampQty(input, Number(input.value || 0) - 1);
        updateDirectSaleTotal();
      });
    });

    qtyInputs.forEach((input) => {
      input.addEventListener("input", updateDirectSaleTotal);
    });

    document.getElementById("clear-order")?.addEventListener("click", () => {
      qtyInputs.forEach((input) => {
        input.value = 0;
      });
      updateDirectSaleTotal();
    });

    directSaleForm?.addEventListener("submit", (event) => {
      if (invoiceSubmitConfirmed) {
        return;
      }

      if (getSelectedItems().length === 0) {
        event.preventDefault();
        return;
      }

      event.preventDefault();
      renderInvoiceConfirm();
      openModal("invoice-confirm-modal");
    });

    confirmCreateInvoiceButton?.addEventListener("click", () => {
      if (!directSaleForm || getSelectedItems().length === 0) return;

      invoiceSubmitConfirmed = true;
      confirmCreateInvoiceButton.disabled = true;
      confirmCreateInvoiceButton.classList.add("opacity-70", "cursor-not-allowed");
      confirmCreateInvoiceButton.textContent = "Membuat invoice...";
      directSaleForm.requestSubmit();
    });

    updateDirectSaleTotal();

    const openModal = (modalId) => {
      const modal = document.getElementById(modalId);
      if (!modal) return;

      modal.classList.remove("hidden");
      modal.classList.add("flex");
    };

    const closeModal = (modalId) => {
      const modal = document.getElementById(modalId);
      if (!modal) return;

      modal.classList.add("hidden");
      modal.classList.remove("flex");
    };

    document.querySelectorAll("[data-open-modal]").forEach((button) => {
      button.addEventListener("click", () => openModal(button.dataset.openModal));
    });

    document.querySelectorAll("[data-close-modal]").forEach((button) => {
      button.addEventListener("click", () => closeModal(button.dataset.closeModal));
    });

    document.querySelectorAll("[data-modal-overlay]").forEach((modal) => {
      modal.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal(modal.id);
        }
      });
    });
  </script>
<%- include("../partials/footer", { flash }) %>
