<%- include("../partials/header", { pageTitle, bodyClass: "bg-[#f8fbff] text-slate-900" }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Manager Panel",
      sidebarDescription: "Pusat pengelolaan endpoint lokal dan integrasi eksternal WarungPOS.",
      sidebarLinks: [
        { href: "/manager", label: "Dashboard", short: "DB" },
        { href: "/manager/api-integrator", label: "API Integrator", short: "API", matchPrefix: "/manager/api-integrator" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="min-w-0 flex-1">
      <header class="border-b border-blue-100 bg-white/90 px-6 py-5 backdrop-blur">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Integration Center</p>
            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">API Integrator</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500">
              Pilih area integrasi. Endpoint lokal terbaca otomatis dari route aplikasi, sedangkan SmartBank, API Gateway, dan UMKM Insight disiapkan sebagai ruang input endpoint eksternal.
            </p>
          </div>
          <a href="/manager" class="rounded-2xl border border-blue-100 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-blue-50">
            Dashboard
          </a>
        </div>
      </header>

      <section class="px-6 py-6">
        <div class="grid gap-4 xl:grid-cols-4">
          <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Local Endpoint</p>
            <div class="mt-4 flex items-end justify-between">
              <p class="text-4xl font-semibold tracking-tight text-slate-950"><%= localApiSummary.total %></p>
              <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Auto scan</span>
            </div>
            <p class="mt-3 text-sm text-slate-500">Endpoint internal dari route Express.</p>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">GET</p>
            <p class="mt-4 text-4xl font-semibold tracking-tight text-blue-700"><%= localApiSummary.get %></p>
            <p class="mt-3 text-sm text-slate-500">Endpoint baca/tampilan.</p>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">POST</p>
            <p class="mt-4 text-4xl font-semibold tracking-tight text-emerald-700"><%= localApiSummary.post %></p>
            <p class="mt-3 text-sm text-slate-500">Endpoint aksi/perubahan data.</p>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">External Provider</p>
            <p class="mt-4 text-4xl font-semibold tracking-tight text-slate-950"><%= providers.length %></p>
            <p class="mt-3 text-sm text-slate-500">SmartBank, Gateway, dan Insight.</p>
          </div>
        </div>

        <div class="mt-6 rounded-xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-200 px-6 py-5">
            <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
              <div>
                <p class="text-sm font-semibold text-blue-600">Integration Directory</p>
                <h3 class="mt-1 text-xl font-semibold text-slate-950">Pilih Integrasi</h3>
                <p class="mt-1 text-sm text-slate-500">Satu daftar untuk dokumentasi endpoint lokal dan pengelolaan endpoint eksternal.</p>
              </div>
              <p class="text-sm text-slate-500"><%= providers.length + 1 %> area integrasi tersedia</p>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">
                <tr>
                  <th class="px-6 py-3">Integrasi</th>
                  <th class="px-6 py-3">Kegunaan</th>
                  <th class="px-6 py-3">Status</th>
                  <th class="px-6 py-3 text-right">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                <tr class="transition hover:bg-slate-50">
                  <td class="px-6 py-5">
                    <div class="flex items-center gap-3">
                      <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-sm font-bold text-blue-700">POS</span>
                      <div>
                        <div class="flex flex-wrap items-center gap-2">
                          <h4 class="font-semibold text-slate-950">Local API</h4>
                          <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-bold text-blue-700">AUTO</span>
                        </div>
                        <p class="mt-1 text-xs text-slate-500">Endpoint internal aplikasi</p>
                      </div>
                    </div>
                  </td>
                  <td class="max-w-xl px-6 py-5 text-slate-600">
                    Dokumentasi otomatis dari file route aplikasi. Endpoint baru di project ini akan terbaca setelah server restart.
                  </td>
                  <td class="px-6 py-5">
                    <div class="flex flex-wrap gap-2">
                      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Total <%= localApiSummary.total %></span>
                      <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">GET <%= localApiSummary.get %></span>
                      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">POST <%= localApiSummary.post %></span>
                    </div>
                  </td>
                  <td class="px-6 py-5 text-right">
                    <a href="/manager/api-integrator/local" class="inline-flex rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800">
                      Buka
                    </a>
                  </td>
                </tr>

                <% providers.forEach((provider) => { %>
                  <tr class="transition hover:bg-slate-50">
                    <td class="px-6 py-5">
                      <div class="flex items-center gap-3">
                        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-100 text-sm font-bold text-slate-700"><%= provider.name.split(" ").map((word) => word[0]).join("").slice(0, 2) %></span>
                        <div>
                          <div class="flex flex-wrap items-center gap-2">
                            <h4 class="font-semibold text-slate-950"><%= provider.name %></h4>
                            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-600">EXTERNAL</span>
                          </div>
                          <p class="mt-1 text-xs text-slate-500">Endpoint dikelola admin</p>
                        </div>
                      </div>
                    </td>
                    <td class="max-w-xl px-6 py-5 text-slate-600"><%= provider.description %></td>
                    <td class="px-6 py-5">
                      <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">UI siap</span>
                    </td>
                    <td class="px-6 py-5 text-right">
                      <a href="/manager/api-integrator/<%= provider.key %>" class="inline-flex rounded-xl border border-blue-100 bg-blue-50 px-4 py-2.5 text-sm font-semibold text-blue-700 transition hover:bg-blue-100">
                        Buka
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </div>
<%- include("../partials/footer", { flash }) %>
