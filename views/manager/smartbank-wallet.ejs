<%- include("../partials/header", { pageTitle, bodyClass: "bg-[#f8fbff] text-slate-900" }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Manager Panel",
      sidebarDescription: "Pantau pembayaran dan kelola wallet penerima toko.",
      sidebarLinks: [
        { href: "/manager", label: "Dashboard", short: "DB", exact: true },
        { href: "/manager/payments", label: "Payment", short: "PY", exact: true },
        { href: "/manager/smartbank-wallet", label: "Wallet Toko", short: "SW", exact: true },
        { href: "/manager/api-integrator", label: "API Integrator", short: "API", matchPrefix: "/manager/api-integrator" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="min-w-0 flex-1">
      <header class="border-b border-blue-100 bg-white/90 px-6 py-5 backdrop-blur">
        <p class="text-sm font-medium text-slate-500">SmartBank</p>
        <h2 class="mt-1 text-3xl font-semibold text-slate-950">Wallet Penerima Toko</h2>
      </header>

      <section class="max-w-3xl px-6 py-6">
        <% if (flash) { %>
          <div class="mb-5 rounded-xl border px-4 py-3 text-sm <%= flash.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-rose-200 bg-rose-50 text-rose-700' %>"><%= flash.message %></div>
        <% } %>

        <div class="border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase text-slate-500">Penerima pembayaran POS</p>
              <h3 class="mt-2 text-xl font-semibold text-slate-950"><%= merchantWallet.linked ? 'Wallet toko terhubung' : 'Tautkan wallet manager' %></h3>
              <p class="mt-2 text-sm text-slate-600">ID penerima: <code class="font-mono text-slate-900"><%= merchantWallet.externalId || '-' %></code></p>
              <% if (merchantWallet.linked) { %><p class="mt-2 text-sm text-slate-600">Wallet ID: <code class="font-mono text-slate-900"><%= merchantWallet.walletId %></code></p><% } %>
              <% if (merchantWallet.error) { %><p class="mt-2 text-sm text-rose-700"><%= merchantWallet.error %></p><% } %>
            </div>
            <span class="w-fit rounded-full px-3 py-1 text-xs font-semibold <%= merchantWallet.linked ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-800' %>"><%= merchantWallet.linked ? 'TERHUBUNG' : 'BELUM TERHUBUNG' %></span>
          </div>

          <% if (!merchantWallet.linked && !merchantWallet.error) { %>
            <% if (!merchantWallet.requestId) { %>
              <form action="/manager/smartbank-wallet/otp/request" method="POST" class="mt-6 flex max-w-xl flex-col gap-3 sm:flex-row">
                <input name="phone" type="tel" inputmode="tel" placeholder="Nomor SmartBank manager, contoh +6281234567890" class="min-w-0 flex-1 border border-slate-300 px-4 py-3 outline-none focus:border-blue-600" required>
                <button class="bg-blue-600 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-700" type="submit">Kirim OTP</button>
              </form>
            <% } else if (!merchantWallet.otpVerified) { %>
              <form action="/manager/smartbank-wallet/otp/verify" method="POST" class="mt-6 flex max-w-xl flex-col gap-3 sm:flex-row">
                <input name="code" type="password" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{6}" maxlength="6" placeholder="OTP 6 digit" class="min-w-0 flex-1 border border-slate-300 px-4 py-3 font-mono outline-none focus:border-blue-600" required>
                <button class="bg-blue-600 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-700" type="submit">Verifikasi OTP</button>
              </form>
            <% } else { %>
              <form action="/manager/smartbank-wallet/link" method="POST" class="mt-6">
                <button class="bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700" type="submit">Tetapkan Wallet Penerima</button>
              </form>
            <% } %>
          <% } %>
        </div>
      </section>
    </main>
  </div>
<%- include("../partials/footer") %>
