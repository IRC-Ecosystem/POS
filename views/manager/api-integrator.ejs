<%- include("../partials/header", { pageTitle, bodyClass: "bg-[#f8fbff] text-slate-900" }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Manager Panel",
      sidebarDescription: "Dokumentasi endpoint aktif, request, response, dan akses API WarungPOS.",
      sidebarLinks: [
        { href: "/manager", label: "Dashboard", short: "DB" },
        { href: "/manager/api-integrator", label: "API Integrator", short: "API", matchPrefix: "/manager/api-integrator" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="min-w-0 flex-1">
      <header class="border-b border-blue-100 bg-white/90 px-6 py-5 backdrop-blur">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Admin Tools</p>
            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">Local API</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500">
              Dokumentasi endpoint aktif dengan gaya Swagger: method, path, parameter, request body, response, akses, dan handler.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <button id="run-api-health-check" type="button" class="rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
              Cek API
            </button>
            <a href="/manager/api-spec.json" target="_blank" class="rounded-2xl bg-slate-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
              Open JSON Spec
            </a>
            <a href="/manager/api-integrator" class="rounded-2xl border border-blue-100 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-blue-50">
              Semua Integrasi
            </a>
          </div>
        </div>
      </header>

      <section class="px-6 py-6">
        <div class="grid gap-4 md:grid-cols-5">
          <div class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-slate-200">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Total Endpoint</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= apiEndpoints.length %></p>
          </div>
          <div class="rounded-3xl bg-blue-50 p-5 ring-1 ring-blue-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-500">GET</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">
              <%= apiEndpoints.filter((endpoint) => endpoint.method === "GET").length %>
            </p>
          </div>
          <div class="rounded-3xl bg-emerald-50 p-5 ring-1 ring-emerald-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-500">POST</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">
              <%= apiEndpoints.filter((endpoint) => endpoint.method === "POST").length %>
            </p>
          </div>
          <div class="rounded-3xl bg-emerald-50 p-5 ring-1 ring-emerald-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-500">API OK</p>
            <p id="api-health-ok-count" class="mt-3 text-3xl font-semibold text-slate-950">-</p>
          </div>
          <div class="rounded-3xl bg-rose-50 p-5 ring-1 ring-rose-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-rose-500">API Gagal</p>
            <p id="api-health-fail-count" class="mt-3 text-3xl font-semibold text-slate-950">-</p>
          </div>
        </div>

        <div class="mt-6 rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
          <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_220px_180px]">
            <input id="api-search" type="search" placeholder="Cari endpoint, handler, fungsi API, atau role" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100">
            <select id="api-group-filter" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100">
              <option value="all">Semua group</option>
              <% apiGroups.forEach((group) => { %>
                <option value="<%= group %>"><%= group %></option>
              <% }) %>
            </select>
            <select id="api-method-filter" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-100">
              <option value="all">GET & POST</option>
              <option value="GET">GET</option>
              <option value="POST">POST</option>
            </select>
          </div>

          <div id="api-empty-state" class="mt-6 hidden rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center">
            <p class="text-sm font-semibold text-slate-700">Endpoint tidak ditemukan.</p>
            <p class="mt-1 text-sm text-slate-500">Ubah kata kunci atau filter method/group.</p>
          </div>

          <div class="mt-6 space-y-4">
            <% apiEndpoints.forEach((endpoint, index) => { %>
              <details
                class="api-doc rounded-3xl border border-slate-200 bg-white shadow-sm"
                data-method="<%= endpoint.method %>"
                data-group="<%= endpoint.group %>"
                data-search="<%= `${endpoint.method} ${endpoint.path} ${endpoint.purpose} ${endpoint.direction} ${endpoint.access} ${endpoint.response}`.toLowerCase() %>"
                data-api-key="<%= `${endpoint.method}:${endpoint.path}` %>"
                <%= index === 0 ? "open" : "" %>
              >
                <summary class="flex cursor-pointer list-none flex-col gap-3 px-5 py-4 lg:flex-row lg:items-center lg:justify-between">
                  <div class="flex min-w-0 flex-1 flex-wrap items-center gap-3">
                    <span class="inline-flex min-w-16 justify-center rounded-full px-3 py-1 text-xs font-bold <%= endpoint.method === 'GET' ? 'bg-blue-100 text-blue-700' : 'bg-emerald-100 text-emerald-700' %>">
                      <%= endpoint.method %>
                    </span>
                    <code class="break-all rounded-lg bg-slate-100 px-2 py-1 text-sm font-semibold text-slate-950"><%= endpoint.path %></code>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= endpoint.group %></span>
                  </div>
                  <div class="flex items-center gap-2 text-xs font-semibold text-slate-500">
                    <span class="api-health-badge rounded-full bg-slate-100 px-3 py-1 text-slate-500" data-health-key="<%= `${endpoint.method}:${endpoint.path}` %>">
                      Belum dicek
                    </span>
                    <span><%= endpoint.response %></span>
                    <span class="text-slate-300">/</span>
                    <span><%= endpoint.access %></span>
                  </div>
                </summary>

                <div class="border-t border-slate-100 px-5 py-5">
                  <p class="text-sm leading-6 text-slate-600"><%= endpoint.purpose %></p>

                  <div class="mt-5 grid gap-4 xl:grid-cols-3">
                    <div class="rounded-2xl bg-slate-50 p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Route Handler</p>
                      <code class="mt-2 block break-all text-sm font-semibold text-slate-900"><%= endpoint.direction %></code>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Authorization</p>
                      <p class="mt-2 text-sm font-semibold text-slate-900"><%= endpoint.access %></p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Response Type</p>
                      <p class="mt-2 text-sm font-semibold text-slate-900"><%= endpoint.response %></p>
                    </div>
                  </div>

                  <div class="api-health-detail mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600" data-health-detail-key="<%= `${endpoint.method}:${endpoint.path}` %>">
                    Status API belum dicek.
                  </div>

                  <div class="mt-5 grid gap-5 xl:grid-cols-2">
                    <div class="rounded-2xl border border-slate-200 p-4">
                      <h4 class="text-sm font-semibold text-slate-950">Parameters</h4>
                      <% const params = [...endpoint.pathParams, ...endpoint.queryParams]; %>
                      <% if (params.length === 0) { %>
                        <p class="mt-3 text-sm text-slate-500">Tidak ada path/query parameter.</p>
                      <% } else { %>
                        <div class="mt-3 space-y-3">
                          <% params.forEach((param) => { %>
                            <div class="rounded-2xl bg-slate-50 p-3">
                              <div class="flex flex-wrap items-center gap-2">
                                <code class="text-sm font-semibold text-slate-900"><%= param.name %></code>
                                <span class="rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-slate-500"><%= param.type %></span>
                                <% if (param.required) { %>
                                  <span class="rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-700">required</span>
                                <% } %>
                              </div>
                              <p class="mt-2 text-sm text-slate-500"><%= param.description %></p>
                              <p class="mt-1 text-xs text-slate-400">Example: <code><%= param.example %></code></p>
                            </div>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>

                    <div class="rounded-2xl border border-slate-200 p-4">
                      <h4 class="text-sm font-semibold text-slate-950">Request Body</h4>
                      <% if (endpoint.bodyFields.length === 0) { %>
                        <p class="mt-3 text-sm text-slate-500">Tidak membutuhkan request body.</p>
                      <% } else { %>
                        <div class="mt-3 space-y-3">
                          <% endpoint.bodyFields.forEach((field) => { %>
                            <div class="rounded-2xl bg-slate-50 p-3">
                              <div class="flex flex-wrap items-center gap-2">
                                <code class="text-sm font-semibold text-slate-900"><%= field.name %></code>
                                <span class="rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-slate-500"><%= field.type %></span>
                                <% if (field.required) { %>
                                  <span class="rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-700">required</span>
                                <% } %>
                              </div>
                              <p class="mt-2 text-sm text-slate-500"><%= field.description %></p>
                            </div>
                          <% }) %>
                        </div>
                        <pre class="mt-4 overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-5 text-slate-100"><code><%= JSON.stringify(endpoint.examplePayload, null, 2) %></code></pre>
                      <% } %>
                    </div>
                  </div>

                  <div class="mt-5 rounded-2xl border border-slate-200 p-4">
                    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                      <h4 class="text-sm font-semibold text-slate-950">Response Example</h4>
                      <button type="button" data-copy-path="<%= endpoint.path %>" class="copy-api-path rounded-2xl border border-slate-200 px-4 py-2 text-xs font-semibold text-slate-600 transition hover:bg-slate-50">
                        Copy Path
                      </button>
                    </div>
                    <pre class="mt-3 overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-5 text-slate-100"><code><%= typeof endpoint.responseExample === "string" ? endpoint.responseExample : JSON.stringify(endpoint.responseExample, null, 2) %></code></pre>
                  </div>
                </div>
              </details>
            <% }) %>
          </div>
        </div>
      </section>
    </main>
  </div>
<%- include("../partials/footer", {
  flash,
  extraScripts: `
    <script>
      (() => {
        const searchInput = document.getElementById("api-search");
        const methodFilter = document.getElementById("api-method-filter");
        const groupFilter = document.getElementById("api-group-filter");
        const docs = [...document.querySelectorAll(".api-doc")];
        const emptyState = document.getElementById("api-empty-state");
        const healthButton = document.getElementById("run-api-health-check");
        const okCount = document.getElementById("api-health-ok-count");
        const failCount = document.getElementById("api-health-fail-count");

        const applyApiFilters = () => {
          const keyword = (searchInput?.value || "").trim().toLowerCase();
          const method = methodFilter?.value || "all";
          const group = groupFilter?.value || "all";
          let visibleCount = 0;

          docs.forEach((doc) => {
            const matchesKeyword = !keyword || doc.dataset.search.includes(keyword);
            const matchesMethod = method === "all" || doc.dataset.method === method;
            const matchesGroup = group === "all" || doc.dataset.group === group;
            const isVisible = matchesKeyword && matchesMethod && matchesGroup;

            doc.classList.toggle("hidden", !isVisible);
            if (isVisible) {
              visibleCount += 1;
            }
          });

          emptyState?.classList.toggle("hidden", visibleCount !== 0);
        };

        [searchInput, methodFilter, groupFilter].forEach((control) => {
          control?.addEventListener("input", applyApiFilters);
          control?.addEventListener("change", applyApiFilters);
        });

        document.querySelectorAll(".copy-api-path").forEach((button) => {
          button.addEventListener("click", async () => {
            await navigator.clipboard?.writeText(button.dataset.copyPath || "");
            button.textContent = "Copied";
            window.setTimeout(() => {
              button.textContent = "Copy Path";
            }, 1200);
          });
        });

        const setHealthBadge = (result) => {
          const badge = [...document.querySelectorAll("[data-health-key]")].find((item) => item.dataset.healthKey === result.key);
          const detail = [...document.querySelectorAll("[data-health-detail-key]")].find((item) => item.dataset.healthDetailKey === result.key);

          if (!badge || !detail) {
            return;
          }

          const isOk = result.status === "ok";
          badge.textContent = (isOk ? "OK " : "Gagal ") + result.code;
          badge.className = "api-health-badge rounded-full px-3 py-1 " + (isOk ? "bg-emerald-100 text-emerald-700" : "bg-rose-100 text-rose-700");
          detail.textContent = result.message;
          detail.className = "api-health-detail mt-5 rounded-2xl border p-4 text-sm " + (isOk ? "border-emerald-200 bg-emerald-50 text-emerald-700" : "border-rose-200 bg-rose-50 text-rose-700");
        };

        const runHealthCheck = async () => {
          if (!healthButton) {
            return;
          }

          healthButton.disabled = true;
          healthButton.textContent = "Mengecek...";

          try {
            const response = await fetch("/manager/api-health.json", {
              headers: { accept: "application/json" }
            });
            const payload = await response.json();

            okCount.textContent = payload.ok;
            failCount.textContent = payload.fail;
            payload.results.forEach(setHealthBadge);
            healthButton.textContent = "Cek Ulang API";
          } catch (error) {
            healthButton.textContent = "Cek Gagal";
          } finally {
            healthButton.disabled = false;
          }
        };

        healthButton?.addEventListener("click", runHealthCheck);
        runHealthCheck();
      })();
    </script>
  `
}) %>
