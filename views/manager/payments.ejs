<%- include("../partials/header", { pageTitle, bodyClass: "bg-[#f8fbff] text-slate-900" }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Manager Panel",
      sidebarDescription: "Pantau payment, transaksi, dan endpoint integrasi dari area manager.",
      sidebarLinks: [
        { href: "/manager", label: "Dashboard", short: "DB", exact: true },
        { href: "/manager/payments", label: "Payment", short: "PY", exact: true },
        { href: "/manager/smartbank-wallet", label: "Wallet Toko", short: "SW", exact: true },
        { href: "/manager/api-integrator", label: "API Integrator", short: "API", matchPrefix: "/manager/api-integrator" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="min-w-0 flex-1">
      <header class="border-b border-blue-100 bg-white/90 px-6 py-5 backdrop-blur">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Payment monitoring</p>
            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">Riwayat Pembayaran</h2>
            <p class="mt-2 text-sm text-slate-500"><%= todayLabel %></p>
          </div>

          <a href="/manager" class="inline-flex w-fit items-center rounded-2xl border border-blue-100 bg-blue-50/70 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-white">
            Kembali ke Dashboard
          </a>
        </div>
      </header>

      <section class="px-6 py-6">
        <% if (typeof dashboardError !== 'undefined' && dashboardError) { %>
          <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= dashboardError %>
          </div>
        <% } %>

        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          <article class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-slate-200">
            <p class="text-sm font-medium text-slate-500">Total Payment</p>
            <p class="mt-4 text-3xl font-semibold text-slate-950"><%= paymentSummary.total %></p>
            <p class="mt-2 text-sm text-slate-500">50 data terbaru</p>
          </article>
          <article class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-slate-200">
            <p class="text-sm font-medium text-slate-500">Success</p>
            <p class="mt-4 text-3xl font-semibold text-emerald-600"><%= paymentSummary.success %></p>
            <p class="mt-2 text-sm text-slate-500">Payment berhasil</p>
          </article>
          <article class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-slate-200">
            <p class="text-sm font-medium text-slate-500">Failed</p>
            <p class="mt-4 text-3xl font-semibold text-rose-600"><%= paymentSummary.failed %></p>
            <p class="mt-2 text-sm text-slate-500">Percobaan gagal</p>
          </article>
          <article class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-slate-200">
            <p class="text-sm font-medium text-slate-500">SmartBank</p>
            <p class="mt-4 text-3xl font-semibold text-blue-600"><%= paymentSummary.smartbank %></p>
            <p class="mt-2 text-sm text-slate-500">Payment via endpoint aktif</p>
          </article>
        </div>

        <section class="mt-6 rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
          <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <h3 class="text-xl font-semibold text-slate-950">Daftar Payment</h3>
              <p class="mt-1 text-sm text-slate-500">Payment disimpan terpisah dari transaksi agar status bayar bisa diaudit.</p>
            </div>
            <span class="w-fit rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
              <%= payments.length %> data
            </span>
          </div>

          <% if (payments.length === 0) { %>
            <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-14 text-center">
              <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-white ring-1 ring-slate-200">
                <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
              <h4 class="mt-4 text-lg font-semibold text-slate-950">Belum ada payment</h4>
              <p class="mt-2 text-sm text-slate-500">Data akan muncul setelah kasir memproses pembayaran.</p>
            </div>
          <% } else { %>
            <div class="mt-6 overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead>
                  <tr class="text-left text-slate-500">
                    <th class="pb-3 font-medium">Invoice</th>
                    <th class="pb-3 font-medium">Metode</th>
                    <th class="pb-3 font-medium">Provider</th>
                    <th class="pb-3 font-medium">Status</th>
                    <th class="pb-3 font-medium">Nominal</th>
                    <th class="pb-3 font-medium">Kasir</th>
                    <th class="pb-3 font-medium">Reference</th>
                    <th class="pb-3 font-medium">Waktu</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% payments.forEach((payment) => { %>
                    <tr class="align-top text-slate-700">
                      <td class="py-4 font-semibold text-slate-900"><%= payment.invoice %></td>
                      <td class="py-4 uppercase"><%= payment.method %></td>
                      <td class="py-4 uppercase"><%= payment.provider %></td>
                      <td class="py-4">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold
                          <%= payment.status === 'success' ? 'bg-emerald-100 text-emerald-700' : '' %>
                          <%= payment.status === 'failed' ? 'bg-rose-100 text-rose-700' : '' %>
                          <%= payment.status === 'pending' ? 'bg-amber-100 text-amber-700' : '' %>
                        ">
                          <%= payment.status %>
                        </span>
                      </td>
                      <td class="py-4 font-medium text-slate-900"><%= payment.amount_formatted %></td>
                      <td class="py-4"><%= payment.cashier_name %></td>
                      <td class="max-w-[280px] break-all py-4 text-xs text-slate-500">
                        <%= payment.reference_label %>
                        <% if (payment.response_code) { %>
                          <span class="mt-1 block font-semibold text-slate-700">HTTP <%= payment.response_code %></span>
                        <% } %>
                      </td>
                      <td class="py-4"><%= payment.paid_at_formatted !== '-' ? payment.paid_at_formatted : payment.created_at_formatted %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>
      </section>
    </main>
  </div>
<%- include("../partials/footer", { flash }) %>
